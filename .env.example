#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
# Copiar este archivo a .env y completar valores. No versionar .env.
# Opcional: en otros entornos se puede usar .env.production, .env.staging, etc.;
# la app por defecto solo carga .env (ver app/docs/CONFIG_ENV.md).
CI_ENVIRONMENT=development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL='http://localhost/montajes-campana/public/'
app.indexPage=''
app.uriProtocol='REQUEST_URI'
app.defaultLocale='es'
app.negotiateLocale=false
app.supportedLocales=['es']
app.appTimezone='America/Argentina/Buenos_Aires'
app.charset='UTF-8'

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
# Conexión principal (obligatoria)
database.default.hostname=localhost
database.default.database=montajes_campana
database.default.username=root
database.default.password=
database.default.DBDriver=MySQLi
database.default.port=3306

# Conexión BD sistema viejo (calibraciones) - usada por comando migrate:olddb
# Si no se definen, se usan los valores por defecto indicados abajo.
# database.old.hostname=localhost
# database.old.database=calibraciones
# database.old.username=root
# database.old.password=
# database.old.DBDriver=MySQLi
# database.old.port=3306

# Conexión BD sistema camiones (equipos) - usada por unidades:completar-desde-camiones
# database.camiones.hostname=localhost
# database.camiones.database=camiones
# database.camiones.username=root
# database.camiones.password=
# database.camiones.DBDriver=MySQLi
# database.camiones.port=3306

#--------------------------------------------------------------------
# AUTH (Google OAuth - login con Gmail)
#--------------------------------------------------------------------
# Crear credenciales en https://console.cloud.google.com/apis/credentials
# Tipo: "Aplicación web" - URI de redirección autorizados: https://tudominio.com/auth/callback (o http://localhost/.../auth/callback en dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# Email del admin (se muestra en la pantalla de "usuario rechazado" para contacto)
ADMIN_EMAIL=

# Opcional: token para llamar a procesar recordatorios desde cron (ej. ?token=xxx)
# NOTIF_RECORDATORIO_TOKEN=

#--------------------------------------------------------------------
# PRODUCCION (descomentar y ajustar en .env de produccion)
#--------------------------------------------------------------------
# app.forceGlobalSecureRequests=true
# app.sessionRegenerateDestroy=true
